{
  "name": "@verevoir/qrcode",
  "version": "1.0.0",
  "description": "Drop-in, zero-dependency replacement for node-qrcode. Same API, 10 visual styles, TypeScript-first, isomorphic (Node, browser, edge).",
  "homepage": "https://verevoir.io",
  "license": "MIT",
  "type": "module",
  "main": "./index.cjs",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.cjs"
    },
    "./node": {
      "types": "./node.d.ts",
      "import": "./node.js",
      "require": "./node.cjs"
    },
    "./web": {
      "types": "./web.d.ts",
      "import": "./web.js",
      "require": "./web.cjs"
    }
  },
  "files": [
    "index.js",
    "index.cjs",
    "index.d.ts",
    "node.js",
    "node.cjs",
    "node.d.ts",
    "web.js",
    "web.cjs",
    "web.d.ts"
  ],
  "keywords": [
    "qrcode",
    "qr",
    "qr-code",
    "qr-generator",
    "qr-code-generator",
    "node-qrcode",
    "svg",
    "svg-qr",
    "styled-qr",
    "typescript",
    "zero-dependencies",
    "drop-in",
    "isomorphic",
    "browser",
    "edge",
    "cloudflare-workers",
    "deno",
    "bun",
    "png"
  ],
  "dependencies": {
    "@verevoir/qr": "^2.0.0"
  },
  "peerDependencies": {
    "@resvg/resvg-js": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@resvg/resvg-js": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:verevoir/qrcode.git"
  },
  "funding": "https://buymeacoffee.com/verevoir"
}
